---
interface Props {
  type?: 'note' | 'tip' | 'warning' | 'danger' | 'important';
  title?: string;
}

const { type = 'note', title } = Astro.props;

const defaultTitles: Record<string, string> = {
  note: 'Note',
  tip: 'Tip',
  warning: 'Warning',
  danger: 'Danger',
  important: 'Important',
};

const label = title ?? defaultTitles[type];
---

<div class={`callout callout-${type}`}>
  <div class="callout-label">{label}</div>
  <div class="callout-body">
    <slot />
  </div>
</div>
