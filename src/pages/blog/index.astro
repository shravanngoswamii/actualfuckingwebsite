---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Base title="Blog" description="Writing. Text. On a page. Revolutionary.">
  <h1>Blog</h1>
  <p>Words I wrote and decided to keep. In reverse chronological order, like a civilized human.</p>
  <hr />
  <ul style="list-style: none; padding: 0;">
    {posts.map((post) => (
      <li style="margin-bottom: 1.5rem;">
        <a href={`/blog/${post.id}`}>{post.data.title}</a>
        <br />
        <span style="font-family: monospace; font-size: 0.85rem;">
          {post.data.date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
        </span>
        {post.data.description && (
          <p style="margin: 0.25rem 0 0;">{post.data.description}</p>
        )}
      </li>
    ))}
  </ul>
</Base>
