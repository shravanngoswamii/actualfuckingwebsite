---
import Base from "../layouts/Base.astro";
---

<Base title="404 — Page Not Found" description="This page does not exist.">
  <h1>404</h1>
  <p>
    The page you're looking for doesn't exist. Either it never did, or it moved
    without leaving a forwarding address, like someone who doesn't want to be
    found.
  </p>
  <p>
    Try the <a href="/">homepage</a>, the <a href="/blog">blog</a>, or just
    accept the void and close the tab.
  </p>
</Base>
