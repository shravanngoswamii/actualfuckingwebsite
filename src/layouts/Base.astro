---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "An actual fucking website. With pages." } = Astro.props;
const site = "actualfuckingwebsite.com";
const nav = [
  { href: "/about", label: "about" },
  { href: "/blog", label: "blog" },
  { href: "/now", label: "now" },
  { href: "/uses", label: "uses" },
  { href: "/contact", label: "contact" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title === site ? site : `${title} — ${site}`}</title>
  </head>
  <body>
    <nav>
      <a href="/" style="font-weight: bold;">{site}</a>
      {nav.map(({ href, label }) => <a href={href}>{label}</a>)}
    </nav>

    <main>
      <slot />
    </main>

    <footer>
      <p>no javascript was harmed in the making of this website</p>
    </footer>
  </body>
</html>
