---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "An actual fucking website. With pages." } = Astro.props;
const site = "actualfuckingwebsite.com";
const nav = [
  { href: "/about", label: "about" },
  { href: "/blog", label: "blog" },
  { href: "/now", label: "now" },
  { href: "/uses", label: "uses" },
  { href: "/contact", label: "contact" },
];

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? `https://${site}`);
const pathname = Astro.url.pathname.replace(/^\/|\/$/g, "");
const ogImagePath = `/og/${pathname || "og"}.png`;
const ogImage = new URL(ogImagePath, Astro.site ?? `https://${site}`).toString();
const pageTitle = title === site ? site : `${title} — ${site}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="alternate" type="application/rss+xml" title={`${site} blog`} href="/rss.xml" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <nav>
      <a href="/" style="font-weight: bold;">{site}</a>
      {nav.map(({ href, label }) => <a href={href}>{label}</a>)}
      <button id="search-trigger" aria-label="Search" title="Search (/)">search</button>
    </nav>

    <main>
      <slot />
    </main>

    <footer>
      <p>no javascript was harmed in the making of this website &mdash; <a href="/rss.xml">rss</a></p>
    </footer>

    <dialog id="search-modal" aria-label="Search">
      <div class="search-modal-header">
        <span>Search</span>
        <button id="search-close" aria-label="Close search">✕</button>
      </div>
      {
        import.meta.env.DEV ? (
          <p class="search-dev-msg">
            Search only works in production. Run{" "}
            <code>npm run build &amp;&amp; npm run preview</code>.
          </p>
        ) : (
          <div id="pagefind-search" />
        )
      }
    </dialog>
  </body>
</html>

<script>
  const modal = document.getElementById("search-modal") as HTMLDialogElement | null;
  const trigger = document.getElementById("search-trigger");
  const closeBtn = document.getElementById("search-close");

  let initialized = false;

  function initSearch() {
    if (initialized || import.meta.env.DEV) return;
    initialized = true;
    const s = document.createElement("script");
    s.src = "/pagefind/pagefind-ui.js";
    s.onload = () => {
      // @ts-ignore — generated by pagefind postbuild
      new PagefindUI({
        element: "#pagefind-search",
        showImages: false,
        resetStyles: false,
      });
    };
    document.head.appendChild(s);
    const link = document.createElement("link");
    link.rel = "stylesheet";
    link.href = "/pagefind/pagefind-ui.css";
    document.head.appendChild(link);
  }

  function openSearch() {
    modal?.showModal();
    initSearch();
    requestAnimationFrame(() => {
      (modal?.querySelector('input[type="text"]') as HTMLInputElement)?.focus();
    });
  }

  function closeSearch() {
    modal?.close();
  }

  trigger?.addEventListener("click", openSearch);
  closeBtn?.addEventListener("click", closeSearch);

  modal?.addEventListener("click", (e) => {
    if (e.target === modal) closeSearch();
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "/" && !["INPUT", "TEXTAREA"].includes((e.target as Element).tagName)) {
      e.preventDefault();
      openSearch();
    }
    if (e.key === "Escape" && modal?.open) {
      closeSearch();
    }
  });
</script>

<script>
  for (const pre of document.querySelectorAll("pre")) {
    const frame = document.createElement("div");
    frame.className = "code-frame";
    pre.parentNode?.insertBefore(frame, pre);
    frame.appendChild(pre);

    const btn = document.createElement("button");
    btn.className = "copy-btn";
    btn.type = "button";
    btn.textContent = "copy";
    btn.setAttribute("aria-label", "Copy code");
    frame.appendChild(btn);

    btn.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(pre.textContent ?? "");
        btn.textContent = "copied";
        btn.setAttribute("data-copied", "");
        setTimeout(() => {
          btn.textContent = "copy";
          btn.removeAttribute("data-copied");
        }, 1500);
      } catch {
        btn.textContent = "failed";
        setTimeout(() => { btn.textContent = "copy"; }, 1500);
      }
    });
  }
</script>
